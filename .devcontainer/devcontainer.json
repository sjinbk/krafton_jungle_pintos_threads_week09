{
    "name": "pintos-dev",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "UBUNTU_PORTS_MIRROR_HTTP": "http://mirror.yuki.net.uk/ubuntu-ports",
            "UBUNTU_PORTS_MIRROR_HTTPS": "https://mirror.yuki.net.uk/ubuntu-ports"
        }
    },
    "remoteUser": "jungle",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cpptools",
                "ms-azuretools.vscode-docker",
                "ms-vscode.makefile-tools"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    }
}
